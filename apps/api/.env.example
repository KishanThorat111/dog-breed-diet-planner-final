# ============================================================
# Dog Breed Diet Planner ï¿½ Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Environment: development | production
ENVIRONMENT=development

# -- Database (required) ---------------------------------------
# Local development:
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase (production) ï¿½ use port 6543 (Transaction Pooler):
# DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# -- Security (required) ---------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# -- Gemini AI (free tier ï¿½ recommended) ----------------------
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# AI settings (optional ï¿½ defaults work fine)
AI_ACTIVE_PROVIDER=gemini
AI_ENABLED=true

# -- Cloudflare R2 Storage (required for image uploads) -------
# Create a free R2 bucket at: https://dash.cloudflare.com
CLOUDFLARE_R2_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-access-key
CLOUDFLARE_R2_BUCKET_NAME=dog-diet-uploads
CLOUDFLARE_R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# -- CORS ------------------------------------------------------
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# -- ML Model --------------------------------------------------
# Local: path to your .pt model file
# Production: leave empty if loading from R2
ML_MODEL_PATH=


