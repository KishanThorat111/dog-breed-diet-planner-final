# ============================================================
# Dog Breed Diet Planner - Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Environment: development | production
ENVIRONMENT=development

# Database (required): local PostgreSQL container (single-VM deployment)
DATABASE_URL=postgresql+asyncpg://dogdiet:change-me-db-password@localhost:5432/dogdiet

# Security (required)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# Gemini AI (required for analyze flow)
GEMINI_API_KEY=your-gemini-api-key
AI_ACTIVE_PROVIDER=gemini
AI_ENABLED=true

# Request caps for moderate demo usage
RATE_LIMIT_PER_MINUTE=120
ANALYZE_RATE_LIMIT_PER_MINUTE=30

# Cloudflare R2 storage (optional; leave blank to skip uploads)
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=dog-breed-diet-planner
CLOUDFLARE_R2_ENDPOINT_URL=
CLOUDFLARE_R2_PUBLIC_URL=

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,https://dogbreeddetector.online,https://www.dogbreeddetector.online


