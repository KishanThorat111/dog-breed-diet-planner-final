# Backend production settings
ENVIRONMENT=production

# Local PostgreSQL container URL
DATABASE_URL=postgresql+asyncpg://dogdiet:change-me-db-password@postgres:5432/dogdiet

# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-random-hex

# AI provider
GEMINI_API_KEY=replace-with-gemini-key
AI_ACTIVE_PROVIDER=gemini
AI_ENABLED=true

# Request caps tuned for e2-medium demo usage
RATE_LIMIT_PER_MINUTE=120
ANALYZE_RATE_LIMIT_PER_MINUTE=30
MAX_UPLOAD_SIZE_MB=10

# Cloudflare R2 (optional; leave blank to skip image uploads)
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=dog-breed-diet-planner
CLOUDFLARE_R2_ENDPOINT_URL=
CLOUDFLARE_R2_PUBLIC_URL=

# Single-domain deployment origin
ALLOWED_ORIGINS=https://dogbreeddetector.online,https://www.dogbreeddetector.online
